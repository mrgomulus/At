# Backend Environment Variables

# Flask Environment (development, production, testing)
FLASK_ENV=development

# Database URL
# For SQLite (development): sqlite:///disruption_management.db
# For MySQL (production): mysql://user:password@hostname:port/database
DATABASE_URL=sqlite:///disruption_management.db

# Secret key for session management
# IMPORTANT: Change this in production!
SECRET_KEY=your-secret-key-here-change-in-production

# Debug mode (True/False)
DEBUG=True

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOGGING_LEVEL=INFO
